#!/usr/bin/env bash
set -euo pipefail

script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
repo_dir="$(cd "$script_dir/.." && pwd)"

print_help() {
  cat <<'EOF'
ptx / pelinkovac-tonik

Usage:
  ptx [command|preset] [options] [project-dir]

Commands:
  ptx help       show this help
  ptx keys       print tmux and Neovim keybindings

Presets:
  ptx            default workspace: shell, work, diff, edit, db shell
  ptx short      shell + editor only
  ptx full       default + running db client
  ptx heavy      default + two runner panes + running db client
  ptx ai         codex + claude mode
  ptx run2       two runner mode
  ptx db         default + running db client
  ptx light      default layout without DB tab

Fun aliases:
  ptx dry        short
  ptx classic    legacy default with Codex pane and one runner
  ptx strong     full
  ptx double     heavy
  ptx lighter    light
  ptx neat       term + edit, no AI, no runner

Options:
  --ai codex|claude|both|none
  --runner none|one|two
  --db           create db window and start a db client
  --no-db        skip db window
  --editor nvim|hx|none
  --diff diffnav|lazygit|delta|none
  --reset        recreate the tmux session
  --kill         kill the tmux session and exit
  --keys         print tmux and Neovim keybindings
  -h, --help     show this help

Window names:
  shell, work, run, diff, edit, db
EOF
}

print_keys() {
  cat "$repo_dir/docs/KEYBINDINGS.md"
}

die() {
  printf 'ptx: %s\n' "$*" >&2
  exit 2
}

have() {
  command -v "$1" >/dev/null 2>&1
}

shell_quote() {
  printf '%q' "$1"
}

detect_root() {
  local start="${1:-$PWD}"
  start="$(cd "$start" && pwd)"
  if git -C "$start" rev-parse --show-toplevel >/dev/null 2>&1; then
    git -C "$start" rev-parse --show-toplevel
  else
    printf '%s\n' "$start"
  fi
}

db_command() {
  local url="${DATABASE_URL:-}"
  if have rainfrog; then
    if [[ -n "$url" ]]; then
      printf 'rainfrog --url %s' "$(shell_quote "$url")"
    else
      printf 'rainfrog'
    fi
  elif have pgcli; then
    if [[ -n "$url" ]]; then
      printf 'pgcli %s' "$(shell_quote "$url")"
    else
      printf 'pgcli'
    fi
  elif have psql; then
    if [[ -n "$url" ]]; then
      printf 'psql %s' "$(shell_quote "$url")"
    else
      printf 'psql'
    fi
  else
    printf "printf '%%s\\n' 'No DB client found. Install rainfrog, pgcli, or psql.'; exec \"${SHELL:-/bin/sh}\" -l"
  fi
}

runner_hint_command() {
  if [[ -f "$project_dir/package.json" ]]; then
    printf 'npm run dev'
  elif [[ -f "$project_dir/go.mod" ]]; then
    printf 'go run .'
  elif [[ -f "$project_dir/Makefile" || -f "$project_dir/makefile" ]]; then
    printf 'make'
  else
    printf 'no runner detected'
  fi
}

send_shell() {
  local pane="$1"
  tmux send-keys -t "$pane" "${SHELL:-/bin/sh} -l" C-m
}

hint_shell_command() {
  local label="$1"
  local command="$2"
  printf 'printf '\''%%s\\n'\'' %s %s %s; exec "${SHELL:-/bin/sh}" -l' \
    "$(shell_quote "$label is ready.")" \
    "$(shell_quote "Run when needed:")" \
    "$(shell_quote "  $command")"
}

ai_hint_command() {
  local tool="$1"
  [[ "$tool" == "none" ]] && return 1
  if [[ "$tool" == "both" ]]; then
    hint_shell_command ai "codex or claude"
    return
  fi
  hint_shell_command "$tool" "$tool"
}

runner_hint_shell_command() {
  local command
  command="$(runner_hint_command)"
  hint_shell_command runner "$command"
}

db_hint_command() {
  hint_shell_command database "$(db_command)"
}

send_editor() {
  local pane="$1"
  local editor="$2"
  case "$editor" in
    nvim|hx)
      if have "$editor"; then
        tmux send-keys -t "$pane" "$editor ." C-m
      else
        tmux send-keys -t "$pane" "printf '%s\n' '$editor not found on PATH.'; exec \"\${SHELL:-/bin/sh}\" -l" C-m
      fi
      ;;
    none)
      send_shell "$pane"
      ;;
  esac
}

send_diff() {
  local pane="$1"
  local diff="$2"
  case "$diff" in
    diffnav)
      if have diffnav; then
        tmux send-keys -t "$pane" "diffnav --watch --watch-cmd $(shell_quote "$repo_dir/bin/tmux-diffnav-diff") --watch-interval 1s" C-m
      else
        tmux send-keys -t "$pane" "printf '%s\n' 'diffnav not found on PATH.'; exec \"\${SHELL:-/bin/sh}\" -l" C-m
      fi
      ;;
    lazygit)
      if have lazygit; then
        tmux send-keys -t "$pane" lazygit C-m
      else
        tmux send-keys -t "$pane" "git status --short; exec \"\${SHELL:-/bin/sh}\" -l" C-m
      fi
      ;;
    delta)
      if have delta; then
        tmux send-keys -t "$pane" "while true; do clear; git diff --color=always | delta; sleep 2; done" C-m
      else
        tmux send-keys -t "$pane" "while true; do clear; git diff --color=always; sleep 2; done" C-m
      fi
      ;;
    none)
      send_shell "$pane"
      ;;
  esac
}

safe_session_name() {
  local name="$1"
  name="${name//[^A-Za-z0-9_-]/_}"
  [[ -n "$name" ]] || name="ptx"
  printf '%s\n' "$name"
}

preset="default"
project_arg=""
reset=0
kill_only=0
ai="codex"
runner="one"
layout="default"
db_window=1
db_run=0
editor="nvim"
diff="diffnav"

if [[ $# -gt 0 ]]; then
  case "$1" in
    help)
      print_help
      exit 0
      ;;
    keys)
      print_keys
      exit 0
      ;;
    short|full|heavy|ai|run2|db|dry|classic|strong|double|light|lighter|neat)
      preset="$1"
      shift
      ;;
  esac
fi

case "$preset" in
  short|dry)
    ai="none"; runner="none"; db_window=0; db_run=0; diff="none"
    ;;
  full|strong|db)
    db_window=1; db_run=1
    ;;
  heavy|double)
    ai="codex"; runner="two"; db_window=1; db_run=1
    ;;
  light|lighter)
    ai="codex"; runner="one"; layout="compact"; db_window=0
    ;;
  ai)
    ai="both"; runner="none"
    ;;
  run2)
    ai="none"; runner="two"
    ;;
  neat)
    ai="none"; runner="none"; db_window=0; db_run=0; diff="none"
    ;;
  classic)
    ai="codex"; runner="one"
    ;;
  default)
    ;;
esac

while [[ $# -gt 0 ]]; do
  case "$1" in
    --ai)
      ai="${2:-}"
      [[ "$ai" =~ ^(codex|claude|both|none)$ ]] || die "--ai must be codex, claude, both, or none"
      shift 2
      ;;
    --runner)
      runner="${2:-}"
      [[ "$runner" =~ ^(none|one|two)$ ]] || die "--runner must be none, one, or two"
      shift 2
      ;;
    --db)
      db_window=1
      db_run=1
      shift
      ;;
    --no-db)
      db_window=0
      db_run=0
      shift
      ;;
    --editor)
      editor="${2:-}"
      [[ "$editor" =~ ^(nvim|hx|none)$ ]] || die "--editor must be nvim, hx, or none"
      shift 2
      ;;
    --diff)
      diff="${2:-}"
      [[ "$diff" =~ ^(diffnav|lazygit|delta|none)$ ]] || die "--diff must be diffnav, lazygit, delta, or none"
      shift 2
      ;;
    --reset)
      reset=1
      shift
      ;;
    --kill)
      kill_only=1
      shift
      ;;
    --keys)
      print_keys
      exit 0
      ;;
    -h|--help)
      print_help
      exit 0
      ;;
    -*)
      die "unknown option $1"
      ;;
    *)
      [[ -z "$project_arg" ]] || die "only one project-dir is supported"
      project_arg="$1"
      shift
      ;;
  esac
done

project_dir="$(detect_root "${project_arg:-$PWD}")"
session_name="$(safe_session_name "$(basename "$project_dir")")"

if [[ "$kill_only" -eq 1 ]]; then
  tmux kill-session -t "$session_name" 2>/dev/null || true
  exit 0
fi

if [[ "$reset" -eq 1 ]]; then
  tmux kill-session -t "$session_name" 2>/dev/null || true
fi

if tmux has-session -t "$session_name" 2>/dev/null; then
  if [[ -n "${TMUX:-}" ]]; then
    tmux switch-client -t "$session_name"
  else
    tmux attach-session -t "$session_name"
  fi
  exit 0
fi

home_pane="$(tmux new-session -d -s "$session_name" -n shell -c "$HOME" -P -F '#{pane_id}')"
repo_pane="$(tmux split-window -h -p 50 -t "$home_pane" -c "$project_dir" -P -F '#{pane_id}')"
tmux select-pane -t "$home_pane" -T home
tmux select-pane -t "$repo_pane" -T repo

if [[ "$layout" == "compact" && "$ai" != "none" && "$runner" == "one" ]]; then
  ai_pane="$(tmux new-window -t "$session_name:" -n work -c "$project_dir" -P -F '#{pane_id}' "$(ai_hint_command "$ai")")"
  runner_pane="$(tmux split-window -h -p 50 -t "$ai_pane" -c "$project_dir" -P -F '#{pane_id}' "$(runner_hint_shell_command)")"
  tmux select-pane -t "$ai_pane" -T ai
  tmux select-pane -t "$runner_pane" -T runner
elif [[ "$ai" != "none" || "$runner" == "one" ]]; then
  if [[ "$ai" != "none" ]]; then
    work_pane="$(tmux new-window -t "$session_name:" -n work -c "$project_dir" -P -F '#{pane_id}' "$(ai_hint_command "$ai")")"
  else
    work_pane="$(tmux new-window -t "$session_name:" -n work -c "$project_dir" -P -F '#{pane_id}')"
  fi
  tmux select-pane -t "$work_pane" -T ai
  if [[ "$ai" == "both" && "$runner" != "one" ]]; then
    codex_pane="$(tmux split-window -h -p 50 -t "$work_pane" -c "$project_dir" -P -F '#{pane_id}' "$(ai_hint_command codex)")"
    tmux select-pane -t "$work_pane" -T claude
    tmux select-pane -t "$codex_pane" -T codex
  elif [[ "$runner" == "one" ]]; then
    runner_pane="$(tmux split-window -h -p 50 -t "$work_pane" -c "$project_dir" -P -F '#{pane_id}' "$(runner_hint_shell_command)")"
    tmux select-pane -t "$runner_pane" -T runner
  fi
fi

if [[ "$runner" == "two" ]]; then
  run1_pane="$(tmux new-window -t "$session_name:" -n run -c "$project_dir" -P -F '#{pane_id}' "$(runner_hint_shell_command)")"
  run2_pane="$(tmux split-window -h -p 50 -t "$run1_pane" -c "$project_dir" -P -F '#{pane_id}' "$(runner_hint_shell_command)")"
  tmux select-pane -t "$run1_pane" -T run
  tmux select-pane -t "$run2_pane" -T run2
fi

if [[ "$diff" != "none" ]]; then
  diff_pane="$(tmux new-window -t "$session_name:" -n diff -c "$project_dir" -P -F '#{pane_id}')"
  tmux select-pane -t "$diff_pane" -T diff
  send_diff "$diff_pane" "$diff"
fi

edit_pane="$(tmux new-window -t "$session_name:" -n edit -c "$project_dir" -P -F '#{pane_id}')"
tmux select-pane -t "$edit_pane" -T edit
send_editor "$edit_pane" "$editor"

if [[ "$db_window" -eq 1 ]]; then
  if [[ "$db_run" -eq 1 ]]; then
    db_pane="$(tmux new-window -t "$session_name:" -n db -c "$project_dir" -P -F '#{pane_id}')"
    tmux select-pane -t "$db_pane" -T db
    tmux send-keys -t "$db_pane" "$(db_command)" C-m
  else
    db_pane="$(tmux new-window -t "$session_name:" -n db -c "$project_dir" -P -F '#{pane_id}' "$(db_hint_command)")"
    tmux select-pane -t "$db_pane" -T db
  fi
fi

tmux select-window -t "$session_name:shell"
tmux select-pane -t "$repo_pane"

if [[ -n "${TMUX:-}" ]]; then
  tmux switch-client -t "$session_name"
else
  tmux attach-session -t "$session_name"
fi
